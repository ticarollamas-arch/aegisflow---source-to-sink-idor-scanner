{
  "python": {
    "sources": ["id", "user_id", "item_id", "account_id", "uuid", "pk"],
    "sinks": ["execute", "filter", "get", "delete", "update", "first", "find", "query"],
    "sanitizers": ["check_owner", "current_user", "authorize", "verify_access", "has_permission"]
